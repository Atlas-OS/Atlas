<# : batch section
@echo off & setlocal enabledelayedexpansion

:: ---- Self-elevate to Administrator ----
net session >nul 2>&1 || (
    powershell -nop -c "Start-Process cmd -ArgumentList '/c \"%~f0\"' -Verb RunAs"
    exit /b
)

:: ---- Decode embedded NSudoLC.exe directly from self ----
set "_exe=%TEMP%\~NSudoLC_%RANDOM%.exe"
certutil -decode "%~f0" "%_exe%" >nul

:: ---- Launch PowerShell as TrustedInstaller via NSudoLC ----
"%_exe%" -U:T -P:E -UseCurrentConsole powershell.exe -nop -ep Bypass -c "Remove-Item '%_exe%' -Force -ErrorAction SilentlyContinue; iex (gc '%~f0' -Raw)"

exit /b

